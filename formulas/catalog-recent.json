[{"id":"notable-identities","name":"Identidades notables","author":"Algebra clasica","year":-300,"field":"Algebra elemental","level":"ESO","color":"#ef4444","folder":"formulas/notable-identities","formula":["(a+b)^2=a^2+2ab+b^2"],"formulaText":["cuadrado de una suma"],"summary":"Patrones algebraicos basicos.","simulation":"notable-identities"},{"id":"arithmetic-progression-sum","name":"Suma de progresion aritmetica","author":"Aritmetica clasica","year":-300,"field":"Aritmetica y algebra","level":"ESO","color":"#f59e0b","folder":"formulas/arithmetic-progression-sum","formula":["a_n=a_1+(n-1)d","S_n=n(a_1+a_n)/2"],"formulaText":["termino n = primer termino + saltos por diferencia","suma = numero de terminos por media entre primero y ultimo"],"summary":"Calcula la suma de terminos separados por una diferencia constante.","simulation":"arithmetic-progression-sum"},{"id":"geometric-progression-sum","name":"Suma de progresion geometrica","author":"Matematica clasica","year":-300,"field":"Aritmetica y algebra","level":"ESO","color":"#06b6d4","folder":"formulas/geometric-progression-sum","formula":["S_n=a_1(r^n-1)/(r-1)"],"formulaText":["suma geometrica"],"summary":"Suma terminos con razon constante.","simulation":"geometric-progression-sum"},{"id":"vietes-formulas","name":"Formulas de Viete","author":"Francois Viete","year":1591,"field":"Algebra","level":"Bachillerato","color":"#14b8a6","folder":"formulas/vietes-formulas","formula":["ax^2+bx+c=a(x-x_1)(x-x_2)","x_1+x_2=-b/a","x_1x_2=c/a"],"formulaText":["suma de raices = menos b partido a","producto de raices = c partido a"],"summary":"Relaciona raices y coeficientes de una ecuacion cuadratica.","simulation":"vietes-formulas"},{"id":"binomial-theorem","name":"Formula del binomio de Newton","author":"Isaac Newton","year":1665,"field":"Algebra y combinatoria","level":"Bachillerato","color":"#a855f7","folder":"formulas/binomial-theorem","formula":["(a+b)^n=sum C(n,k)a^(n-k)b^k"],"formulaText":["potencia de una suma"],"summary":"Expande potencias de binomios.","simulation":"binomial-theorem"}]
